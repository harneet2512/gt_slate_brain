#!/usr/bin/env bash
# gt_query — L4 GroundTruth query tool (SWE-agent bundle entrypoint)
# Forwards to lib/gt_query.py. graph.db path comes from $GT_GRAPH_DB.
# Per-instance log dir comes from $GT_INSTANCE_LOG_DIR.
set -u
THIS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUNDLE_DIR="$(dirname "$THIS_DIR")"
PY="${GT_PYTHON:-python3}"
exec "$PY" "$BUNDLE_DIR/lib/gt_query.py" "$@"
