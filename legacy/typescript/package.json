{
  "name": "groundtruth",
  "version": "0.1.0",
  "description": "MCP server — codebase intelligence for AI coding agents",
  "type": "module",
  "bin": {
    "groundtruth": "./dist/bin/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "benchmark": "python benchmarks/runner.py --fixture all",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "cursor",
    "hallucination",
    "validation",
    "ai-coding"
  ],
  "author": "HSB",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "openai": "^6.27.0",
    "pino": "^9.0.0",
    "ts-morph": "^23.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
